# LegisBot Backend — Railway Deployment
# Fill these in Railway Dashboard → Variables

# 🔐 Security (REQUIRED)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256

# 🗄️ Database (REQUIRED — add PostgreSQL plugin on Railway)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/legisbot

# 🤖 AI (Optional — OpenAI API key)
# Without this, the app falls back to template-based document generation
OPENAI_API_KEY=sk-your-openai-api-key
AI_MODEL=gpt-4o
AI_TEMPERATURE=0.3
MAX_TOKENS=4096

# 🚀 Railway
RAILWAY_PUBLIC_DOMAIN=your-backend-url.up.railway.app

# 💳 Payment (Optional — for subscriptions)
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# 📧 Email (Optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-key
FROM_EMAIL=noreply@legisbot.com

# 📦 Storage (Optional — for document uploads)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_BUCKET_NAME=legisbot-documents
AWS_REGION=ap-south-1
